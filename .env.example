# ============================================================================
# StudyHub Frontend Environment Variables
# ============================================================================
# Copy this file to .env.development.local and fill in the values

# API Configuration
# The backend API URL - used for all API calls
VITE_API_URL=http://localhost:5000/api

# Feature Flags
# Enable/disable features in development
VITE_DEBUG_MODE=false

# Analytics (optional)
# For Vercel Web Analytics
VITE_WEB_ANALYTICS_ID=

# Third-party Services (future use)
# For AI Tutor feature
VITE_OPENAI_API_KEY=

# ============================================================================
# Development Notes
# ============================================================================
# - VITE_API_URL: Must match the backend server URL and port
#   Local: http://localhost:5000/api
#   Production: https://your-api-domain.com/api
#
# - VITE_DEBUG_MODE: Set to 'true' for detailed console logs
#   Only effects development - production always logs minimally
#
# - Never commit real API keys or secrets to git
#   Use .env.local for local development (git-ignored)
