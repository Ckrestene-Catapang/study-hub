# ============================================================================
# StudyHub Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string
# Local development: postgresql://user:password@localhost:5432/studyhub_dev
# Production: postgresql://user:password@db-host:5432/studyhub_prod (from cloud provider)
DATABASE_URL=postgresql://user:password@localhost:5432/studyhub_dev

# Optional: Database pool settings
DB_POOL_SIZE=20
DB_POOL_IDLE_TIMEOUT=30000

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Secret: Generate with: openssl rand -base64 32
# MUST be different for development and production
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT expiry time (e.g., "7d", "24h", "7200s")
JWT_EXPIRY=7d

# ============================================================================
# Server Configuration
# ============================================================================
# Port the backend server listens on
PORT=5000

# Environment: development, staging, production
NODE_ENV=development

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origin for frontend requests
# Local: http://localhost:3000
# Production: https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# Feature Flags
# ============================================================================
# Allow new user registration
ENABLE_REGISTRATION=true

# Allow password reset flow
ENABLE_PASSWORD_RESET=true

# ============================================================================
# Third-party Services (Future Use)
# ============================================================================
# OpenAI Configuration (for future AI Tutor feature)
OPENAI_API_KEY=sk-...

# Email Service Configuration (for notifications and password reset)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@studyhub.local
SENDGRID_API_KEY=SG.xxxx...

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file size in bytes (10MB default)
MAX_FILE_SIZE=10485760

# Directory for file uploads
UPLOAD_DIR=./uploads

# ============================================================================
# Development Notes
# ============================================================================
# 1. Database Setup:
#    - Create PostgreSQL database matching DATABASE_URL
#    - Run: npm run db:init (to initialize schema)
#
# 2. JWT Secret:
#    - NEVER use the default in production
#    - Generate secure secret: openssl rand -base64 32
#    - Store securely (use environment secrets, not in git)
#
# 3. CORS Configuration:
#    - LOCAL: http://localhost:3000
#    - VERCEL: https://your-domain.vercel.app
#    - PRODUCTION: https://your-production-domain.com
#
# 4. Environment Files:
#    - .env (git-ignored) - local development
#    - Use environment secrets in production (not .env files)
#
# 5. Security:
#    - Never commit .env to git
#    - Rotate JWT_SECRET periodically
#    - Use strong passwords for database
#    - Enable HTTPS in production
